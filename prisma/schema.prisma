generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

enum ListingType {
  ROOM
  APARTMENT
  HOUSE
  STUDIO
}

enum ListingStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  REJECTED
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ReportReason {
  FAKE
  DUPLICATE
  INAPPROPRIATE
  WRONG_INFO
  OTHER
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  VNPAY
  MOMO
  ZALOPAY
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum NotificationType {
  LISTING_APPROVED
  LISTING_REJECTED
  LISTING_EXPIRED
  NEW_MESSAGE
  NEW_REVIEW
  NEW_REPORT
  SUBSCRIPTION_EXPIRING
  PAYMENT_SUCCESS
  PAYMENT_FAILED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  phone         String?    @unique
  name          String
  avatarUrl     String?
  password      String
  role          Role       @default(TENANT)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false)
  phoneVerified Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sessions         UserSession[]
  listings         Listing[]
  reviews          Review[]
  reviewReplies    ReviewReply[]
  savedListings    SavedListing[]
  reports          Report[]         @relation("ReporterReports")
  resolvedReports  Report[]         @relation("ResolverReports")
  subscriptions    Subscription[]
  payments         Payment[]
  notifications    Notification[]
  listingViews     ListingView[]
  chatsAsUser1     Chat[]           @relation("User1Chats")
  chatsAsUser2     Chat[]           @relation("User2Chats")
  sentMessages     Message[]
  listingHistories ListingHistory[]
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Address {
  id       String  @id @default(cuid())
  street   String
  ward     String?
  district String
  city     String
  province String
  lat      Float
  lng      Float

  listings Listing[]

  @@index([lat, lng])
  @@index([district])
  @@index([city])
}

model Listing {
  id             String        @id @default(cuid())
  ownerId        String
  addressId      String
  title          String
  type           ListingType   @default(ROOM)
  price          Int
  area           Float
  electricityFee Int?
  waterFee       Int?
  description    String?
  utilities      String[]
  images         String[]
  contactName    String?
  contactPhone   String?
  status         ListingStatus @default(DRAFT)
  viewCount      Int           @default(0)
  expiredAt      DateTime?
  rejectedAt     DateTime?
  rejectNote     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  owner        User             @relation(fields: [ownerId], references: [id])
  address      Address          @relation(fields: [addressId], references: [id])
  history      ListingHistory[]
  views        ListingView[]
  savedByUsers SavedListing[]
  reviews      Review[]
  reports      Report[]
  chats        Chat[]

  @@index([ownerId])
  @@index([status])
  @@index([status, expiredAt])
  @@index([price])
  @@index([area])
  @@index([type])
}

model ListingHistory {
  id        String         @id @default(cuid())
  listingId String
  changedBy String
  oldStatus ListingStatus?
  newStatus ListingStatus
  note      String?
  createdAt DateTime       @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [changedBy], references: [id])

  @@index([listingId])
}

model ListingView {
  id        String   @id @default(cuid())
  listingId String
  userId    String?
  ipAddress String?
  viewedAt  DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([listingId])
  @@index([viewedAt])
}

model SavedListing {
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
}

model Review {
  id         String   @id @default(cuid())
  listingId  String
  userId     String
  rating     Int
  comment    String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listing Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id])
  replies ReviewReply[]
  reports Report[]

  @@unique([listingId, userId])
  @@index([listingId])
}

model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([reviewId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  listingId  String?
  reviewId   String?
  reason     ReportReason
  detail     String?
  status     ReportStatus @default(PENDING)
  resolvedBy String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  reporter User     @relation("ReporterReports", fields: [reporterId], references: [id])
  resolver User?    @relation("ResolverReports", fields: [resolvedBy], references: [id])
  listing  Listing? @relation(fields: [listingId], references: [id])
  review   Review?  @relation(fields: [reviewId], references: [id])

  @@index([status])
  @@index([listingId])
  @@index([reviewId])
}

model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  priceVnd     Int
  maxListings  Int
  durationDays Int
  featured     Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([status, endAt])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  subscriptionId String
  amount         Int
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  txnRef         String?       @unique
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  user         User         @relation(fields: [userId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  refId     String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Chat {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  listingId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1    User      @relation("User1Chats", fields: [user1Id], references: [id])
  user2    User      @relation("User2Chats", fields: [user2Id], references: [id])
  listing  Listing?  @relation(fields: [listingId], references: [id])
  messages Message[]

  @@unique([user1Id, user2Id, listingId])
  @@index([user1Id])
  @@index([user2Id])
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  senderId  String
  content   String
  type      MessageType @default(TEXT)
  isRead    Boolean     @default(false)
  readAt    DateTime?
  createdAt DateTime    @default(now())

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id])

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ListingStatus {
  DRAFT // Chủ trọ đang soạn, chưa đăng
  PENDING // Chờ admin duyệt
  ACTIVE // Đang hiển thị công khai
  PAUSED // Chủ trọ tạm ẩn
  EXPIRED // Hết hạn đăng (sau 60 ngày)
  REJECTED // Admin từ chối
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  password      String
  emailVerified Boolean  @default(false)

  listings      Listing[]
  reviews       Review[]
  savedListings SavedListing[]

  // Chat relations
  chatsAsUser1 Chat[] @relation("User1Chats")
  chatsAsUser2 Chat[] @relation("User2Chats")
  sentMessages Message[] @relation("SentMessages")
}

model Listing {
  id             String   @id @default(cuid())
  title          String
  address        String
  lat            Float
  lng            Float
  price          Int // monthly rent in VND
  area           Float // square meters
  electricityFee Int? // VND per kWh
  waterFee       Int? // VND per m³
  description    String?
  utilities      String[] // e.g. ["air_conditioning", "balcony", "wifi", "parking", "washing_machine"]
  images         String[] // URLs
  contactName    String?
  contactPhone   String?
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  status     ListingStatus @default(DRAFT)
  expiredAt  DateTime? // null cho đến khi ACTIVE, set khi duyệt
  rejectedAt DateTime?
  rejectNote String? // Lý do admin từ chối

  owner        User           @relation(fields: [ownerId], references: [id])
  reviews      Review[]
  savedByUsers SavedListing[]
  chats        Chat[]

  @@index([lat, lng])
  @@index([price])
  @@index([area])
  @@index([status])
  @@index([status, expiredAt])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int // 1-5
  comment   String?
  listingId String
  userId    String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([listingId, userId])
}

model SavedListing {
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
}

model Chat {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Participants in the chat
  user1Id String
  user2Id String
  user1   User   @relation("User1Chats", fields: [user1Id], references: [id])
  user2   User   @relation("User2Chats", fields: [user2Id], references: [id])

  // Related listing (optional - chat might be about a specific listing)
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id])

  messages Message[]

  @@unique([user1Id, user2Id, listingId])
  @@index([user1Id])
  @@index([user2Id])
  @@index([listingId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isRead    Boolean  @default(false)
  readAt    DateTime?

  // Sender
  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  // Chat room
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
}

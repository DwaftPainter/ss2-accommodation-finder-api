# Database configuration
# Get this from your database provider (Neon, Supabase, etc.)
DATABASE_URL="postgresql://example/neondb?sslmode=require&channel_binding=require"

# Node environment
NODE_ENV="development"

# JWT secret for authentication
# Generate a secure random string for production
JWT_SECRET_KEY="your secret key"

# Redis configuration for caching
# Get these from your Redis provider (Upstash, etc.)
UPSTASH_REDIS_REST_URL="https://example.com"
UPSTASH_REDIS_REST_TOKEN="your token"

# SMTP configuration for email notifications
# Configure these with your email provider settings
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_SECURE="true"
SMTP_FROM="noreply@accommodationfinder.com"

# Frontend URL for email verification and password reset links
FRONTEND_URL="http://localhost:5173"

# AI Provider configuration
# Currently supports 'openai' (default)
AI_PROVIDER="openai"
OPENAI_API_KEY="your_openai_api_key_here"  # Get this from https://platform.openai.com/api-keys
AI_MODEL="gpt-3.5-turbo"